@startuml
title Validation Workflow (Code + Hardware Gate)

start
:Run unit tests\npython3 -m unittest discover -s tests -p 'test_*.py' -v;
if (All tests pass?) then (yes)
  :Validate CLI entry points\n./tools/exp --help\n./tools/exp --list-target-profiles;
  if (CLI validation pass?) then (yes)
    :Hardware readiness check\n./tools/exp --list-devices;
    if (Device visible?) then (yes)
      :Dry-run capture\n./tools/exp capture ... --dry-run-packets 5;
      if (Packets > 0?) then (yes)
        :Execute experiment capture plan;
      else (no)
        :Record blocked by TX not running\nor no CSI stream;
      endif
    else (no)
      :Fix serial permissions / cable / board power;
    endif
  else (no)
    :Fix CLI/config errors;
  endif
else (no)
  :Fix regressions before any capture;
endif
:Update docs/experiments/validation_report.md;
stop

@enduml
