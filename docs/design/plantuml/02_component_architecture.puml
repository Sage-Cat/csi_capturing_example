@startuml
title Common Experiment Architecture (Code View)

skinparam packageStyle rectangle
skinparam shadowing false

package "Entry Points" {
  [tools/exp]
  [python -m csi_capture.experiment]
  [scripts/run_*]
}

package "CLI Layer" {
  [csi_capture.cli]
  [csi_capture.experiment]
}

package "Core Shared Modules" {
  [core/environment.py]
  [core/device.py]
  [core/dataset.py]
  [core/features.py]
  [core/models.py]
  [core/evaluation.py]
}

package "Experiment Modules" {
  [experiments/static_sign_v1.py]
  [experiments/distance.py]
  [angle runner in experiment.py]
}

package "Capture/Parse" {
  [capture.py]
  [parser.py]
}

database "Storage" {
  [experiments/<exp_id>/...]
  [data/experiments/static_sign_v1/...]
  [artifacts/...]
  [out/...]
}

[tools/exp] --> [csi_capture.cli]
[python -m csi_capture.experiment] --> [csi_capture.experiment]
[scripts/run_*] --> [csi_capture.cli]
[scripts/run_*] --> [csi_capture.experiment]

[csi_capture.cli] --> [core/environment.py]
[csi_capture.cli] --> [core/device.py]
[csi_capture.cli] --> [experiments/static_sign_v1.py]
[csi_capture.cli] --> [experiments/distance.py]

[csi_capture.experiment] --> [core/environment.py]
[csi_capture.experiment] --> [core/device.py]
[csi_capture.experiment] --> [capture.py]

[experiments/static_sign_v1.py] --> [capture.py]
[experiments/static_sign_v1.py] --> [core/dataset.py]
[experiments/static_sign_v1.py] --> [core/features.py]
[experiments/static_sign_v1.py] --> [core/models.py]
[experiments/static_sign_v1.py] --> [core/evaluation.py]
[experiments/static_sign_v1.py] --> [Storage]

[experiments/distance.py] --> [csi_capture.experiment]
[csi_capture.experiment] --> [Storage]
[capture.py] --> [parser.py]

@enduml
