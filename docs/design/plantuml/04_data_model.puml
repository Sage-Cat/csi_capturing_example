@startuml
title Data Model - Common Environment + Experiment Runs

hide methods
hide circle

class EnvironmentProfile {
  +profile_id: str
  +board: str
  +chip: str
  +esp_idf_version: str
  +tx_firmware: str
  +rx_firmware: str
  +default_serial_device: str
  +default_baud: int
}

class ExperimentConfig {
  +experiment_type: str
  +exp_id: str
  +run_ids: list[str]
  +target_profile: EnvironmentProfile
  +scenario_tags: list[str]
  +device.path: str
  +capture.packets_per_repeat: int?
  +capture.duration_s: float?
}

class RunManifest {
  +exp_id: str
  +experiment_type: str
  +run_id: str
  +target_profile: str
  +environment_profile: object
  +device.path: str
  +trials: list<object>
  +status: running|completed|interrupted
}

class TrialPacketRow {
  +timestamp: int
  +rssi: int
  +csi: list[int]
  +exp_id: str
  +experiment_type: str
  +target_profile: str
  +run_id: str
  +trial_id: str
}

class StaticSignMetadata {
  +schema_version: int
  +experiment_name: static_sign_v1
  +label: baseline|hands_up
  +target_profile: str
  +environment_profile: object
  +device: str
  +chip: str
  +serial_dev: str
}

EnvironmentProfile <-- ExperimentConfig
ExperimentConfig --> RunManifest
RunManifest --> TrialPacketRow
EnvironmentProfile <-- StaticSignMetadata
StaticSignMetadata --> TrialPacketRow

@enduml
