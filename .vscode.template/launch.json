{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Distance Analysis",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/analyze_wifi_distance_measurement.py",
      "console": "integratedTerminal",
      "args": [
        "--data_dir",
        "${workspaceFolder}/experiments/${input:expId}",
        "--out_dir",
        "${workspaceFolder}/out/distance_measurement"
      ]
    },
    {
      "name": "Stability Analysis",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/analyze_wifi_stability_statistics.py",
      "console": "integratedTerminal",
      "args": [
        "--data_dir",
        "${workspaceFolder}/experiments/${input:expId}",
        "--out_dir",
        "${workspaceFolder}/out/stability_statistics"
      ]
    }
  ],
  "inputs": [
    {
      "id": "expId",
      "type": "promptString",
      "description": "Experiment id (folder under experiments/)",
      "default": "exp_2026_02_23_lab"
    }
  ]
}
