{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CSI: Capture (continuous)",
      "type": "shell",
      "command": "python3",
      "args": [
        "-m",
        "csi_capture.capture",
        "-p",
        "/dev/esp32_csi",
        "-b",
        "921600",
        "-o",
        "data/csi_capture.jsonl",
        "--format",
        "jsonl"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "CSI: Capture (smoke 5 records)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "timeout 30s python3 -m csi_capture.capture -p /dev/esp32_csi -b 921600 -o data/csi_capture_verify.jsonl --format jsonl --max-records 5; status=$?; echo \"capture_exit=$status\"; wc -l data/csi_capture_verify.jsonl 2>/dev/null || true; test $status -ne 124"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "CSI: Serial monitor (raw)",
      "type": "shell",
      "command": "bash",
      "args": [
        "-lc",
        "stty -F /dev/esp32_csi 921600 raw -echo -echoe -echok; cat /dev/esp32_csi"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "CSI: Watch output (tail -f)",
      "type": "shell",
      "command": "tail",
      "args": [
        "-f",
        "data/csi_capture.jsonl"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
